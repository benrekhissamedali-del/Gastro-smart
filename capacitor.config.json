{
  "appId": "tn.restogest.app",
  "appName": "RestoGest",
  "webDir": "dist",
  "android": {
    "allowMixedContent": false,
    "captureInput": true,
    "backgroundColor": "#0a0a0a"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#0a0a0a",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0a0a0a"
    }
  },
  "server": {
    "androidScheme": "https",
    "cleartext": false
  }
}
